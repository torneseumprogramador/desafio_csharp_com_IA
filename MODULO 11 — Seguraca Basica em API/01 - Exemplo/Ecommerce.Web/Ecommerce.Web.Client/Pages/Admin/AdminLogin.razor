@page "/admin"
@layout TemplateAdminLoginLayout
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))

@inject AdminAuthState AuthState
@inject NavigationManager Navigation

<PageTitle>Admin — Entrar</PageTitle>

<OrganismLoginForm />

@code {
    protected override async Task OnInitializedAsync()
    {
        await AuthState.RestoreFromStorageAsync();
        if (AuthState.IsAuthenticated)
        {
            Navigation.NavigateTo("/admin/administradores");
        }
    }
}
