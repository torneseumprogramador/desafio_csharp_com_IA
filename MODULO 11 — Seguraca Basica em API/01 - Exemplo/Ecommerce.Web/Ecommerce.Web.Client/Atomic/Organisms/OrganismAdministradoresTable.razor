<table class="w-full border-collapse text-sm">
    <thead>
    <tr>
        <th class="border-b border-slate-700 px-3 py-2.5 text-left text-xs font-semibold uppercase tracking-wider text-slate-400">Id</th>
        <th class="border-b border-slate-700 px-3 py-2.5 text-left text-xs font-semibold uppercase tracking-wider text-slate-400">Nome</th>
        <th class="border-b border-slate-700 px-3 py-2.5 text-left text-xs font-semibold uppercase tracking-wider text-slate-400">E-mail</th>
        <th class="border-b border-slate-700 px-3 py-2.5 text-left text-xs font-semibold uppercase tracking-wider text-slate-400">Perfil</th>
    </tr>
    </thead>
    <tbody>
    @if (Carregando)
    {
        <tr>
            <td class="border-b border-slate-700 px-3 py-2.5 text-slate-300" colspan="4">
                <AtomText>Carregando administradores…</AtomText>
            </td>
        </tr>
    }
    else if (Itens is null || Itens.Count == 0)
    {
        <tr>
            <td class="border-b border-slate-700 px-3 py-2.5 text-slate-300" colspan="4">
                <AtomText>Nenhum administrador encontrado.</AtomText>
            </td>
        </tr>
    }
    else
    {
        @foreach (var item in Itens)
        {
            <tr class="hover:bg-slate-900/50">
                <td class="border-b border-slate-700 px-3 py-2.5 text-slate-200">@item.Id</td>
                <td class="border-b border-slate-700 px-3 py-2.5 text-slate-200">@item.Nome</td>
                <td class="border-b border-slate-700 px-3 py-2.5 text-slate-200">@item.Email</td>
                <td class="border-b border-slate-700 px-3 py-2.5">
                    <AtomBadge>@item.Rule</AtomBadge>
                </td>
            </tr>
        }
    }
    </tbody>
</table>

@code {
    [Parameter] public bool Carregando { get; set; }

    [Parameter] public IReadOnlyList<AdministradorResponse>? Itens { get; set; }
}
