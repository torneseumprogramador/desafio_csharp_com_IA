# Template de variaveis para dotenv.
# - Este arquivo pode ser versionado.
# - Antes de rodar, copie `.env.source` para `.env` e ajuste os valores.
#
# Variaveis esperadas pelo `ClienteRepositorioMySql`:
# - MYSQL_HOST
# - MYSQL_PORT
# - MYSQL_DATABASE
# - MYSQL_USER
# - MYSQL_PASSWORD

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=projeto_pratico_clientes
MYSQL_USER=root
MYSQL_PASSWORD=SUA_SENHA_AQUI

